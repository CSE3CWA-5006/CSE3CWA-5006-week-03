generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id        String   @id
  name      String
  email     String   @unique
  major     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("students")
}
